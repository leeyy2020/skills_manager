#!/usr/bin/env python3
from pathlib import Path
import runpy
import sys


SCRIPT = (
    Path(__file__).resolve().parent
    / "skills"
    / "skills-manager"
    / "scripts"
    / "manage_skills.py"
)


if __name__ == "__main__":
    sys.argv[0] = str(Path(__file__).resolve())
    runpy.run_path(str(SCRIPT), run_name="__main__")
